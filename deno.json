{
  "tasks": {
    "dev": "deno run --allow-run --allow-read --allow-write --allow-env src/main.ts",
    "test": "deno test --allow-read --allow-write --allow-env",
    "lint": "deno lint",
    "check": "deno check src/main.ts",
    "compile": "deno compile --allow-run --allow-read --allow-write --allow-env --output dist/moonlight-awdl src/main.ts",
    "release": "deno run --allow-run --allow-read --allow-write --allow-env scripts/release.ts"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "exclude": [".idea", "dist"]
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "compilerOptions": {
    "strict": true
  }
}
